SECRET_KEY=your-django-secret-key-here
DEBUG=True

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/billcraft?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-jwt-secret-key-at-least-32-chars-long
JWT_EXPIRATION=43200000

# SMTP Email
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_HOST_USER=your-mailtrap-username
EMAIL_HOST_PASSWORD=your-mailtrap-password

# Frontend URL (for CORS and password reset links)
FRONTEND_URL=http://localhost:5173

# Server
PORT=5000
